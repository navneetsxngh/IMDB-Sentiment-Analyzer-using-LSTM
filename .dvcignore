# DVC ignore file — patterns listed here are excluded from DVC tracking

# Python bytecode
**/__pycache__
**/*.pyc
**/*.pyo

# Virtual environments
IMDBenv/
venv/
.venv/
env/

# Jupyter checkpoints
**/.ipynb_checkpoints

# OS noise
**/.DS_Store
**/Thumbs.db

# IDE
**/.idea
**/.vscode

# Logs
logs/
*.log

# Temporary files
*.tmp
*.temp
