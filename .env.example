# ── Kaggle API Credentials ───────────────────────────────────────
# Get your key at: https://www.kaggle.com/settings → API → Create New Token
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ── MLflow Tracking ──────────────────────────────────────────────
# Local file-based backend (default — no server needed)
# Run `mlflow ui` to view at http://localhost:5000
MLFLOW_TRACKING_URI=mlruns
MLFLOW_EXPERIMENT_NAME=IMDB_Sentiment_Analysis

# ── DagsHub Remote (uncomment to use) ───────────────────────────
# Free hosting for both DVC remote and MLflow tracking
# Sign up at: https://dagshub.com
# MLFLOW_TRACKING_URI=https://dagshub.com/your_username/your_repo.mlflow
# MLFLOW_TRACKING_USERNAME=your_dagshub_username
# MLFLOW_TRACKING_PASSWORD=your_dagshub_access_token

# ── Self-Hosted MLflow Server (uncomment to use) ─────────────────
# MLFLOW_TRACKING_URI=http://localhost:5000

# ── AWS / GCP / Azure Managed MLflow (uncomment to use) ──────────
# MLFLOW_TRACKING_URI=databricks
# DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
# DATABRICKS_TOKEN=your_databricks_pat
